# Server Configuration
PORT=3001
NODE_ENV=development

# Anthropic (read by @ai-sdk/anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# Backend MCP route (called by gateway/src/core/mcp-client.ts)
MCP_BASE_URL=http://localhost:3000/mcp

# HS256 secret shared with backend; gateway signs short-lived JWTs (5-min TTL)
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here

# Set to 1 to opt into evalite scenarios under gateway/evals
RUN_EVALS=0
